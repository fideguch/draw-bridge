{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["src/engine/*"],
      "@render/*": ["src/render/*"],
      "@meta/*": ["src/meta/*"],
      "@platform/*": ["src/platform/*"],
      "@tuning/*": ["src/tuning/*"]
    }
  },
  "include": ["src", "tests", "scripts", "vite.config.ts", "playwright.config.ts", "capacitor.config.ts"]
}
