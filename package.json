{
  "name": "inkbridge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "gates": "vite-node scripts/gates/run-gates.ts",
    "atlas": "vite-node scripts/atlas/build-atlas.ts",
    "spike:bench": "vite-node scripts/spike/bench.ts",
    "spike:determinism": "vite-node scripts/spike/determinism.ts",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/preferences": "^7.0.4",
    "phaser": "^4.2.0",
    "phaser-box2d": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^7.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.7"
  }
}
